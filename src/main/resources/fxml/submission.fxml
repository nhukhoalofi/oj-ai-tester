<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
			xmlns:fx="http://javafx.com/fxml/1"
			fx:controller="com.yourteam.ojaitester.controller.SubmissionController"
			prefHeight="900.0" prefWidth="1400.0">

	<children>
		<VBox AnchorPane.topAnchor="12.0"
			  AnchorPane.leftAnchor="12.0"
			  AnchorPane.rightAnchor="12.0"
			  AnchorPane.bottomAnchor="12.0"
			  spacing="12"
			  style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8;">

			<children>
				<HBox spacing="10" alignment="CENTER_LEFT">
					<children>
						<Label text="Submissions"
							   style="-fx-font-size: 24; -fx-font-weight: bold;" />
						<Label fx:id="statusLabel" text="Select a problem to begin." />
						<Region HBox.hgrow="ALWAYS" />
						<Button fx:id="btnRefresh"
								text="Refresh"
								onAction="#handleRefreshSubmissions" />
					</children>
				</HBox>

				<GridPane hgap="10" vgap="10">
					<columnConstraints>
						<ColumnConstraints prefWidth="110" />
						<ColumnConstraints hgrow="ALWAYS" />
						<ColumnConstraints prefWidth="90" />
						<ColumnConstraints hgrow="ALWAYS" />
					</columnConstraints>

					<children>
						<Label text="Problem" GridPane.rowIndex="0" GridPane.columnIndex="0" />
						<ComboBox fx:id="problemComboBox"
								  onAction="#handleProblemSelected"
								  GridPane.rowIndex="0"
								  GridPane.columnIndex="1" />

						<Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="2" />
						<TextField fx:id="submissionNameField"
								   promptText="e.g. AC_solution_1"
								   GridPane.rowIndex="0"
								   GridPane.columnIndex="3" />

						<Label text="Type" GridPane.rowIndex="1" GridPane.columnIndex="0" />
						<ComboBox fx:id="submissionTypeComboBox"
								  GridPane.rowIndex="1"
								  GridPane.columnIndex="1" />

						<Label text="Language" GridPane.rowIndex="1" GridPane.columnIndex="2" />
						<TextField fx:id="languageField"
							   editable="false"
							   focusTraversable="false"
							   style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151;"
								   GridPane.rowIndex="1"
								   GridPane.columnIndex="3" />
					</children>
				</GridPane>

				<HBox spacing="10">
					<children>
						<Button fx:id="btnSave"
								text="Save"
								onAction="#handleSaveSubmission" />
						<Button fx:id="btnRun"
								text="Run All Testcases"
								onAction="#handleRunSubmission" />
						<Button fx:id="btnClear"
								text="Clear"
								onAction="#handleClearForm" />
					</children>
				</HBox>

				<SplitPane dividerPositions="0.52">
					<items>
						<VBox spacing="8" prefWidth="640">
							<children>
								<Label text="C++ Source Code" style="-fx-font-weight: bold;" />
								<TextArea fx:id="sourceCodeArea"
										  wrapText="false"
										  prefRowCount="28"
										  promptText="#include &lt;iostream&gt; ..." />
							</children>
						</VBox>

						<VBox spacing="10" prefWidth="720">
							<children>
								<Label text="Saved Submissions for selected problem" style="-fx-font-weight: bold;" />
								<TableView fx:id="submissionTable" prefHeight="220">
									<columns>
										<TableColumn fx:id="colSubmissionId" text="ID" prefWidth="70" />
										<TableColumn fx:id="colSubmissionName" text="Name" prefWidth="220" />
										<TableColumn fx:id="colSubmissionType" text="Type" prefWidth="80" />
										<TableColumn fx:id="colLanguage" text="Lang" prefWidth="90" />
										<TableColumn fx:id="colCreatedAt" text="Created At" prefWidth="140" />
									</columns>
								</TableView>

								<Label text="Run Results by testcase" style="-fx-font-weight: bold;" />
								<TableView fx:id="resultTable" prefHeight="220">
									<columns>
										<TableColumn fx:id="colResultTestcaseId" text="Testcase ID" prefWidth="90" />
										<TableColumn fx:id="colResultCategory" text="Category" prefWidth="90" />
										<TableColumn fx:id="colResultStatus" text="Status" prefWidth="100" />
										<TableColumn fx:id="colResultRuntimeMs" text="Runtime" prefWidth="100" />
										<TableColumn fx:id="colResultMemoryKb" text="Memory" prefWidth="100" />
										<TableColumn fx:id="colResultExpectedOutput" text="Expected output" prefWidth="160" />
										<TableColumn fx:id="colResultActualOutput" text="Actual output" prefWidth="160" />
										<TableColumn fx:id="colResultErrorMessage" text="Error message" prefWidth="200" />
									</columns>
								</TableView>

								<GridPane hgap="8" vgap="8">
									<columnConstraints>
										<ColumnConstraints prefWidth="110" />
										<ColumnConstraints hgrow="ALWAYS" />
									</columnConstraints>
									<children>
										<Label text="Input" GridPane.rowIndex="0" GridPane.columnIndex="0" />
										<TextArea fx:id="resultInputArea" editable="false" wrapText="true" prefRowCount="3" GridPane.rowIndex="0" GridPane.columnIndex="1" />

										<Label text="Expected" GridPane.rowIndex="1" GridPane.columnIndex="0" />
										<TextArea fx:id="resultExpectedArea" editable="false" wrapText="true" prefRowCount="3" GridPane.rowIndex="1" GridPane.columnIndex="1" />

										<Label text="Actual" GridPane.rowIndex="2" GridPane.columnIndex="0" />
										<TextArea fx:id="resultActualArea" editable="false" wrapText="true" prefRowCount="3" GridPane.rowIndex="2" GridPane.columnIndex="1" />

										<Label text="Error" GridPane.rowIndex="3" GridPane.columnIndex="0" />
										<TextArea fx:id="resultErrorArea" editable="false" wrapText="true" prefRowCount="3" GridPane.rowIndex="3" GridPane.columnIndex="1" />
									</children>
								</GridPane>

								<Label text="Run Summary" style="-fx-font-weight: bold;" />
								<TextArea fx:id="runSummaryArea"
										  editable="false"
										  wrapText="true"
										  prefRowCount="6"
										  promptText="Run results will appear here." />
							</children>
						</VBox>
					</items>
				</SplitPane>
			</children>
		</VBox>
	</children>

	<padding>
		<Insets top="12" right="12" bottom="12" left="12" />
	</padding>
</AnchorPane>


