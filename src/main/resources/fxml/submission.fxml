<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.yourteam.ojaitester.controller.SubmissionController"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <children>
        <Label text="Code Submission"
               style="-fx-font-size: 24; -fx-font-weight: bold;" />

        <!-- Problem Name -->
        <VBox spacing="6">
            <Label text="Problem Name" style="-fx-font-weight: bold;" />
            <TextField fx:id="problemNameField" promptText="Enter problem name (e.g., sum, factorial)" />
        </VBox>

        <!-- Code Input -->
        <VBox spacing="6" VBox.vgrow="ALWAYS">
            <Label text="C++ Code" style="-fx-font-weight: bold;" />
            <TextArea fx:id="codeArea"
                      promptText="Paste your C++ code here..."
                      wrapText="false"
                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11;"
                      VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Test Cases Split Pane -->
        <Label text="Test Cases" style="-fx-font-weight: bold; -fx-font-size: 12;" />
        <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
            <items>
                <!-- Input -->
                <VBox spacing="6">
                    <Label text="Input" style="-fx-font-weight: bold;" />
                    <TextArea fx:id="inputArea"
                              promptText="Enter test input here..."
                              wrapText="false"
                              style="-fx-font-family: 'Courier New'; -fx-font-size: 11;"
                              VBox.vgrow="ALWAYS" />
                </VBox>

                <!-- Expected Output -->
                <VBox spacing="6">
                    <Label text="Expected Output" style="-fx-font-weight: bold;" />
                    <TextArea fx:id="expectedOutputArea"
                              promptText="Enter expected output here..."
                              wrapText="false"
                              style="-fx-font-family: 'Courier New'; -fx-font-size: 11;"
                              VBox.vgrow="ALWAYS" />
                </VBox>
            </items>
        </SplitPane>

        <!-- Action Buttons -->
        <HBox spacing="10" style="-fx-padding: 10;">
            <children>
                <Button text="Submit" fx:id="submitButton"
                        onAction="#handleSubmit"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;"
                        HBox.hgrow="ALWAYS" />
                <Button text="Clear" fx:id="clearButton"
                        onAction="#handleClear"
                        style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-padding: 10 30;" />
            </children>
        </HBox>

        <!-- Result Section -->
        <VBox spacing="6" style="-fx-border-color: #e5e7eb; -fx-border-radius: 5; -fx-padding: 15; -fx-background-color: white;">
            <Label text="Test Result" style="-fx-font-weight: bold; -fx-font-size: 14;" />

            <!-- Verdict -->
            <HBox spacing="10">
                <Label text="Verdict:" style="-fx-font-weight: bold;" />
                <Label fx:id="verdictLabel" text="Waiting..." style="-fx-text-fill: #6b7280;" />
            </HBox>

            <!-- Execution Time -->
            <HBox spacing="10">
                <Label text="Time:" style="-fx-font-weight: bold;" />
                <Label fx:id="timeLabel" text="- ms" />
            </HBox>

            <!-- Actual Output -->
            <Label text="Actual Output:" style="-fx-font-weight: bold;" />
            <TextArea fx:id="actualOutputArea"
                      wrapText="false"
                      editable="false"
                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11; -fx-control-inner-background: #f3f4f6;"
                      prefRowCount="6" />

            <!-- Error Message (if any) -->
            <Label text="Error Message:" style="-fx-font-weight: bold;" />
            <TextArea fx:id="errorMessageArea"
                      wrapText="false"
                      editable="false"
                      style="-fx-font-family: 'Courier New'; -fx-font-size: 11; -fx-control-inner-background: #fef2f2;"
                      prefRowCount="4" />
        </VBox>
    </children>

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
</VBox>


