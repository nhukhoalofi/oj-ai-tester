<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yourteam.ojaitester.controller.ProblemListController"
            prefHeight="800.0" prefWidth="1200.0">

    <children>
        <VBox AnchorPane.topAnchor="12.0"
              AnchorPane.leftAnchor="12.0"
              AnchorPane.rightAnchor="12.0"
              AnchorPane.bottomAnchor="12.0"
              spacing="12"
              style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 8;">

            <children>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <children>
                                <Label text="Danh sách đề bài"
                               style="-fx-font-size: 24; -fx-font-weight: bold;" />
                        <TextField fx:id="searchField"
                                                   promptText="Tìm theo tiêu đề / loại nguồn..."
                                   prefWidth="320" />
                                        <Label fx:id="statusLabel" text="Sẵn sàng" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="loadingLabel" text="Đang tải dữ liệu..." visible="false" />
                        <Button fx:id="btnRefresh"
                                text="Làm mới"
                                onAction="#handleRefresh" />
                    </children>
                </HBox>

                <SplitPane dividerPositions="0.58">
                    <items>
                        <VBox spacing="8" prefWidth="650">
                            <children>
                                <Label text="Danh sách đề bài" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                                <TableView fx:id="problemTable" prefHeight="640">
                                    <columns>
                                        <TableColumn fx:id="colId" text="Mã đề" prefWidth="70" />
                                        <TableColumn fx:id="colTitle" text="Tiêu đề" prefWidth="250" />
                                        <TableColumn fx:id="colSourceType" text="Nguồn" prefWidth="110" />
                                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="110" />
                                        <TableColumn fx:id="colCreatedAt" text="Ngày tạo" prefWidth="150" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="10" prefWidth="420" style="-fx-padding: 4 0 0 8;">
                            <children>
                                <Label text="Chi tiết đề bài" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                                <Label fx:id="detailTitle"
                                       text="Chọn một đề để xem chi tiết"
                                       wrapText="true"
                                       style="-fx-font-size: 18; -fx-font-weight: bold;" />

                                <GridPane hgap="8" vgap="8">
                                    <columnConstraints>
                                        <ColumnConstraints prefWidth="110" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>

                                    <children>
                                        <Label text="Loại nguồn:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                        <Label fx:id="detailSourceType" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                                        <Label text="Trạng thái:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                        <Label fx:id="detailStatus" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                                        <Label text="Ngày tạo:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                        <Label fx:id="detailCreatedAt" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                                        <Label text="Đường dẫn nguồn:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                        <Label fx:id="detailSourcePath"
                                               text="-"
                                               wrapText="true"
                                               GridPane.rowIndex="3"
                                               GridPane.columnIndex="1" />
                                    </children>
                                </GridPane>

                                <Label text="Nội dung thô" style="-fx-font-weight: bold;" />
                                <TextArea fx:id="detailRawText"
                                          editable="false"
                                          wrapText="true"
                                          prefRowCount="18"
                                          promptText="Nội dung đề sẽ hiển thị ở đây" />

                                <HBox spacing="8" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="btnOpenSourceFile"
                                                text="Mở file nguồn"
                                                onAction="#handleOpenSourceFile" />
                                        <Button fx:id="btnDelete"
                                                text="Xóa đề"
                                                onAction="#handleDelete"
                                                style="-fx-background-color: #ef4444; -fx-text-fill: white;" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </items>
                </SplitPane>
            </children>
        </VBox>
    </children>

    <padding>
        <Insets top="12" right="12" bottom="12" left="12" />
    </padding>
</AnchorPane>
