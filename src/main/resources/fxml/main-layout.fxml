<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.fxml.FXMLLoader?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yourteam.ojaitester.controller.MainLayoutController">

    <left>
        <VBox spacing="10" prefWidth="220" style="-fx-background-color: #1f2937; -fx-padding: 20;">
            <children>
                <Label text="OJ AI Tester" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <Label text="Add Problem" style="-fx-text-fill: white;"/>
                <Label text="Problem List" style="-fx-text-fill: white;"/>
                <Label text="AI Analysis" style="-fx-text-fill: white;"/>
                <Label text="Testcases" style="-fx-text-fill: white;"/>
                <Label text="Submissions" style="-fx-text-fill: white;"/>
                <Label text="Evaluation" style="-fx-text-fill: white;"/>
            </children>
        </VBox>
    </left>

    <center>
        <fx:include source="problem-form.fxml"/>
    </center>

</BorderPane>