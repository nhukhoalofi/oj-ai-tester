<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.yourteam.ojaitester.controller.ProblemFormController"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: white;">

    <children>
        <Label text="Add Problem"
               style="-fx-font-size: 24; -fx-font-weight: bold;" />

        <VBox spacing="6">
            <Label text="Title" />
            <TextField fx:id="titleField" promptText="Enter problem title" />
        </VBox>

        <VBox spacing="6">
            <Label text="Source Type" />
            <ComboBox fx:id="sourceTypeComboBox" prefWidth="250" />
        </VBox>

        <HBox spacing="10">
            <children>
                <Button text="Choose File"
                        onAction="#handleChooseFile" />
                <Label fx:id="selectedFileLabel" text="No file selected" />
            </children>
        </HBox>

        <VBox spacing="6">
            <Label text="Problem Statement" />
            <TextArea fx:id="rawTextArea"
                      promptText="Enter problem statement here or load from file..."
                      wrapText="true"
                      prefRowCount="16" />
        </VBox>

        <HBox spacing="10">
            <children>
                <Button text="Load Text From File"
                        onAction="#handleLoadFromFile" />
                <Button text="Save Problem"
                        onAction="#handleSaveProblem"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" />
                <Button text="Clear"
                        onAction="#handleClearForm" />
            </children>
        </HBox>
    </children>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
</VBox>